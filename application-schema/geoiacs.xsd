							<documentation>--Name--
animal welfare

-- Definition --
Indicates the presence or not of subsidies related to animal welfare according to Art. 31 of  R (EU) 2021/2115</documentation>
						</annotation>
					</element>
					<element name="beginLifespanVersion" type="dateTime">
